{
  "title": "CEU Webinars Glow Up",
  "body": "<html><body><div id=\"block-ti-west-content\">\n<article>\n<div>\n<div>\n\n<div class=\"hero__container hero__container--text-dark hero__container--no-overlay\" data-hero-container=\"\">\n<div class=\"container container--max-width\">\n<div class=\"hero__text-inset\">\n<div class=\"container__grid container__grid--2col\">\n<div class=\"hero__text-container none\">\n<h1 class=\"u-margin-hug u-font-family-secondary hero__title montserratbold\">CEU Webinars Glow Up</h1>\n<p class=\"u-font-family-primary hero__sub-title\">Comprehensive, relevant CE—now with more options. Build your schedule with in-demand topics, earn state-approved credits, and enjoy transparent pricing with no reporting fees or hidden costs.</p>\n</div>\n\n</div>\n\n</div>\n\n</div>\n\n</div>\n\n</div>\n<div>\n<div class=\"paragraph paragraph--type--embed-view paragraph--view-mode--default container container--max-width webinar--listing-view\">\n<div class=\"webinar-view\">\n<h2 class=\"webinar-list-upcoming-title u-padding-md-bottom\">Upcoming Webinars</h2>\n<div><div class=\"views-element-container\">\n<section class=\"webinar-listing-results js-view-dom-id-ee27f18fd827d44f69fd76a5c461669bfcba66c62985618f027a1ddf49797d68 u-padding-md-bottom\">\n<div class=\"filter-exposed-form u-margin-lg-bottom\">\n<form accept-charset=\"UTF-8\" action=\"/admin/reports/webinar-stats\" class=\"views-exposed-form bef-exposed-form\" data-drupal-selector=\"views-exposed-form-ceu-webinars-webinar-block\" id=\"views-exposed-form-ceu-webinars-webinar-block\" method=\"get\">\n</form><form class=\"views-exposed-form bef-exposed-form\" data-drupal-selector=\"views-exposed-form-ceu-webinars-webinar-block\">\n<div class=\"filter-title\">\n<span class=\"h4 u-margin-hug\">Filter By Date</span>\n<hr aria-hidden=\"true\" class=\"hr--sm\" role=\"presentation\"/>\n</div>\n<div class=\"js-form-item form-item js-form-type-date form-item-field-start-value-1 js-form-item-field-start-value-1\">\n<label for=\"edit-field-start-v