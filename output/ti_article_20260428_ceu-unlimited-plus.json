{
  "title": "CEU Unlimited+",
  "body": "<html><body><div id=\"block-ti-west-content\">\n<article>\n<div>\n<div>\n\n<div class=\"hero__container hero__container--small hero__container--text-dark hero__container--white_overlay_center\" data-hero-container=\"\">\n<div class=\"container container--max-width\">\n<div class=\"hero__text-container hero__text-container--center hero__text-container__small\">\n<h1 class=\"u-font-family-secondary hero__title montserratbold\">CEU Unlimited+</h1>\n</div>\n\n\n</div>\n\n</div>\n\n</div>\n<div>\n<section>\n<div class=\"container container--max-width\">\n<article class=\"container__grid media-block__container media-block__container--reversed\">\n<div class=\"media-block__img-container\">\n<img alt=\"A group of professionals viewed from overhead at staggered intervals with bar graph panels behind them\" src=\"/sites/default/files/styles/right_aligned/public/2024-12/CompetitiveAdvantage.webp?itok=IISLYp_2\" srcset=\"/sites/default/files/styles/right_aligned/public/2024-12/CompetitiveAdvantage.webp?itok=IISLYp_2 1x, /sites/default/files/styles/right_aligned_2x/public/2024-12/CompetitiveAdvantage.webp?itok=7TXzSUz0  2x\"/>\n</div>\n\n<div class=\"media-block__header\">\n<h2 class=\"u-margin-hug\">\n            Transform Your Team With An Advanced CE Solution\n          </h2>\n<hr aria-hidden=\"true\" class=\"hr hr--offset hr--md hr--md--offset hr--light\" role=\"presentation\"/>\n</div>\n\n<div class=\"media-block__content\">\n<p><span>Stay ahead in today’s competitive landscape with a scalable CE solution designed to strengthen enterprise performance. Offer your licensed professionals access to comprehensive learning options and unlimited CE that helps them stay on track. With one predictable price and no fees, CEU Unlimited+ simplifies CE management while maximizing value.</span></p>\n</div>\n\n</article>\n</div>\n</section>\n\n</div>\n<div> <div class=\"paragraph paragraph--type--steps paragraph--view-mode--default\">\n<div>\n<div>\n<div class=\"paragraph paragraph--type--steps-card paragraph--view-mode--default\">\n<svg class=\"u-icon-light-bulb-flat-dims\">\n<use xlink:href=\"#light-bulb-flat\"></use>\n</svg>\n<div class=\"steps-label\">Strengthen risk management and insurance knowledge to stay up-to-date and compliant.</div>\n<div class=\"arrow-right\">\n<svg aria-hidden=\"true\" class=\"u-icon-arrow-right\" role=\"presentation\">\n<use xlink:href=\"#arrow-right\" xmlns:xlink=\"http://www.w3.org/1999/xlink\"></use>\n</svg>\n</div>\n</div>\n</div>\n<div>\n<div class=\"paragraph paragraph--type--steps-card paragraph--view-mode--default\">\n<svg class=\"u-icon-level-flat-dims\">\n<use xlink:href=\"#level-flat\"></use>\n</svg>\n<div class=\"steps-label\">Improve client service by understanding the complexities of risk management.</div>\n<div class=\"arrow-right\">\n<svg aria-hidden=\"true\" class=\"u-icon-arrow-right\" role=\"presentation\">\n<use xlink:href=\"#arrow-right\" xmlns:xlink=\"http://www.w3.org/1999/xlink\"></use>\n</svg>\n</div>\n</div>\n</div>\n<div>\n<div class=\"paragraph paragraph--type--steps-card paragraph--view-mode--default\">\n<svg class=\"u-icon-target-flat-dims\">\n<use xlink:href=\"#target-flat\"></use>\n</svg>\n<div class=\"steps-label\">Support team member career growth to enhance credibility.</div>\n<div class=\"arrow-right\">\n<svg aria-hidden=\"true\" class=\"u-icon-arrow-right\" role=\"presentation\">\n<use xlink:href=\"#arrow-right\" xmlns:xlink=\"http://www.w3.org/1999/xlink\"></use>\n</svg>\n</div>\n</div>\n</div>\n<div>\n<div class=\"paragraph paragraph--type--steps-card paragraph--view-mode--default\">\n<svg class=\"u-icon-trusted-flat-dims\">\n<use xlink:href=\"#trusted-flat\"></use>\n</svg>\n<div class=\"steps-label\">Promote your organization as a well-informed, ethical, and efficient workforce.</div>\n<div class=\"arrow-right\">\n<svg aria-hidden=\"true\" class=\"u-icon-arrow-right\" role=\"presentation\">\n<use xlink:href=\"#arrow-right\" xmlns:xlink=\"http://www.w3.org/1999/xlink\"></use>\n</svg>\n</div>\n</div>\n</div>\n</div>\n</div>\n</div>\n<div>\n<section class=\"basic-content__container\">\n<div class=\"container container--max-width\">\n<article class=\"container__grid container__grid--offset-left\">\n<div class=\"basic-content__copy\">\n<h2 class=\"u-margin-hug\">The CEU Advantage</h2>\n<hr aria-hidden=\"true\" class=\"hr--offset hr--md hr--md--offset hr--light\" role=\"presentation\"/>\n<p><span>Empower your team to meet CE requirements efficiently while expanding their expertise through relevant, expert-led content. With flexible learning and real-time engagement from on-demand courses and live webinars, CEU Unlimited+ keeps organizations compliant and competitive.</span></p>\n</div>\n\n</article>\n\n</div>\n\n</section>\n\n</div>\n<div>\n<div class=\"container container--max-width paragraph paragraph--type--text paragraph--type--text--bleed paragraph--view-mode--default\">\n<div><div data-aspectratio=\"2.43809524\" data-mobile-aspectratio=\"0.86021505\" data-tablet-aspectratio=\"1.95047619\" id=\"experience-67589bf74e6f8\" style=\"border-style:none;border-width:0;bottom:0;height:0;left:0;margin:0;padding:0 0 41.02%;position:relative;right:0;top:0;width:auto;\"></div></div>\n</div>\n</div>\n<div> <div class=\"paragraph paragraph--type--highlight-bar paragraph--view-mode--default\">\n<div class=\"u-margin-top u-margin-lg-bottom highlight-bar__container highlight-bar__container--navy\">\n<div class=\"container--max-width\">\n<div class=\"container__grid container__grid--centered container__grid--max-md\">\n<div class=\"highlight-bar__inner\">\n<div class=\"highlight-bar__msg u-text-left\">\n<h3>Already Powered by CEU Unlimited+? Let’s Get Started.</h3>\n<p><span>Keep your momentum going with unlimited access to CEU’s on-demand courses and webinars. Discover the learning opportunities to help you meet your CE requirements and take your professional growth even further.</span></p>\n</div>\n\n<div class=\"highlight-bar__cta\">\n<div>\n<div class=\"paragraph paragraph--type--cta paragraph--view-mode--default\">\n<a class=\"btn btn--secondary btn--secondary--light\" href=\"/ceu/ceu-for-you\">\n        Explore Your Unlimited CE Now\n      </a>\n</div>\n</div>\n</div>\n</div>\n\n</div>\n\n</div>\n\n</div>\n\n</div>\n</div>\n<div>\n<section class=\"basic-content__container\">\n<div class=\"container container--max-width\">\n<article class=\"container__grid container__grid--offset-left\">\n<div class=\"basic-content__copy\">\n<h2 class=\"u-margin-hug\">Learn About A CEU Partnership Opportunity</h2>\n<hr aria-hidden=\"true\" class=\"hr--offset hr--md hr--md--offset hr--light\" role=\"presentation\"/>\n<div class=\"_form_41 active_campaign_form\"> </div>\n</div>\n\n</article>\n\n</div>\n\n</section>\n\n</div>\n<div>\n<div class=\"container container--max-width paragraph paragraph--type--text paragraph--type--text--bleed paragraph--view-mode--default\">\n<div><div data-aspectratio=\"2.56513026\" data-mobile-aspectratio=\"0.5625\" data-tablet-aspectratio=\"0.75\" id=\"experience-67cefa8ef1752\" style=\"border-style:none;border-width:0;bottom:0;height:0;left:0;margin:0;padding:0 0 38.98%;position:relative;right:0;top:0;width:auto;\"></div></div>\n</div>\n</div>\n<div>\n<div class=\"container container--max-width paragraph paragraph--type--text paragraph--view-mode--default\">\n<div><div data-aspectratio=\"2.40150094\" data-mobile-aspectratio=\"0.67796610\" id=\"experience-69c448b1a1cc1\" style=\"border-style:none;border-width:0;bottom:0;height:0;left:0;margin:0;padding:0 0 41.64%;position:relative;right:0;top:0;width:auto;\"></div></div>\n</div>\n</div>\n<div>\n<div class=\"container container--max-width paragraph paragraph--type--text paragraph--view-mode--default\">\n<div><div data-aspectratio=\"2.06451613\" data-mobile-aspectratio=\"1.14893617\" data-tablet-aspectratio=\"0.75\" id=\"experience-67cf073bea6a1\" style=\"border-style:none;border-width:0;bottom:0;height:0;left:0;margin:0;padding:0 0 48.44%;posi